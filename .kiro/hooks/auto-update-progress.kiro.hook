{
  "enabled": true,
  "name": "Auto Update Progress",
  "description": "Runs progress.py to regenerate PROGRESS.md whenever a .java or .py solution file is saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.java",
      "**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "python progress.py"
  }
}